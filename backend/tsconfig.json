{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*Routes.ts",
    "src/controllers/assignmentController.ts",
    "src/controllers/availabilityController.ts",
    "src/controllers/configController.ts",
    "src/controllers/guideRequestController.ts",
    "src/controllers/notificationController.ts",
    "src/controllers/panelController.ts",
    "src/controllers/reportController.ts",
    "src/controllers/reviewController.ts",
    "src/controllers/rolesController.ts",
    "src/controllers/studentController.ts",
    "src/controllers/teamController.ts",
    "src/config/socket.ts",
    "src/middleware/rateLimit.ts",
    "src/middleware/rbac.ts",
    "src/queues/**/*",
    "src/services/docxService.ts",
    "src/services/schedulerService.ts",
    "src/validators/reviewValidators.ts",
    "src/scripts/**/*"
  ]
}
